<Window x:Class="plexrefresh.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:plexrefresh"
        xmlns:vm="clr-namespace:plexrefresh.ViewModels"
        mc:Ignorable="d"
        Title="Plex Refresh" Height="500" Width="850" Icon="icon.png"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="15">
        <TabControl>
            <TabItem Header="{Binding CurrentStrings.MainTabHeader}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="{Binding CurrentStrings.LibraryLabel}" FontWeight="Bold" Margin="0,0,0,5" Foreground="{StaticResource AccentBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Libraries}"
                                      SelectedItem="{Binding SelectedLibrary}"
                                      DisplayMemberPath="Title" />
                            <Button Grid.Column="1" Content="{Binding CurrentStrings.RefreshButton}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RefreshLibraryCommand}"
                                    Width="120" Margin="10,0,0,0" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="{Binding CurrentStrings.FolderLabel}" FontWeight="Bold" Margin="0,0,0,5" Foreground="{StaticResource AccentBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Folders}"
                                      SelectedItem="{Binding SelectedFolder}"
                                      DisplayMemberPath="Path" />
                            <Button Grid.Column="1" Content="{Binding CurrentStrings.RefreshButton}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RefreshFolderCommand}"
                                    Width="120" Margin="10,0,0,0" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="{Binding Status}"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                </Grid>
            </TabItem>

            <TabItem Header="{Binding CurrentStrings.ConfigTabHeader}">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Language toggle -->
                    <Button Grid.Row="0" Grid.Column="1"
                            Content="{Binding CurrentStrings.LanguageButton}"
                            Command="{Binding ToggleLanguageCommand}"
                            HorizontalAlignment="Right"
                            Width="40" Height="24" Margin="0,0,0,15" />

                    <!-- Server URL -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding CurrentStrings.ServerUrlLabel}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,15" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                    <!-- Token -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding CurrentStrings.TokenLabel}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,15" />
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox x:Name="TokenTextBox" Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTokenVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <PasswordBox x:Name="TokenBox" PasswordChanged="TokenBox_PasswordChanged">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTokenVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>
                        </Grid>

                        <Button Grid.Column="1"
                                Command="{Binding ToggleTokenVisibilityCommand}"
                                Content="👁"
                                FontSize="16"
                                Width="40" Height="Auto"
                                Margin="10,0,0,0"
                                Padding="0"
                                ToolTip="{Binding CurrentStrings.ToggleTokenTooltip}" />
                    </Grid>

                    <!-- Buttons -->
                    <UniformGrid Grid.Row="3" Grid.Column="1" Columns="3" Margin="0,15,0,0">
                        <Button Content="{Binding CurrentStrings.SaveButton}" Command="{Binding SaveConfigCommand}" Height="35" Margin="0,0,5,0" />
                        <Button Content="{Binding CurrentStrings.CheckAuthButton}" Command="{Binding CheckAuthCommand}" Height="35" Margin="5,0,5,0" />
                        <Button Content="{Binding CurrentStrings.ReloadLibsButton}" Command="{Binding ReloadLibrariesCommand}" Style="{StaticResource PrimaryButton}" Height="35" Margin="5,0,0,0" />
                    </UniformGrid>

                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ConfigStatus}"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,10,0,0" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                </Grid>
            </TabItem>
            <TabItem Header="{Binding CurrentStrings.AboutTabHeader}">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                        <TextBlock Text="Plex Refresh"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12" />

                        <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4">
                            <Run Text="Version: " FontWeight="SemiBold" />
                            <Run Text="{Binding AppVersion, Mode=OneTime}" />
                        </TextBlock>

                        <TextBlock Text="© PolzeSoft 2026"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <TextBlock HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Hyperlink NavigateUri="https://polze.net"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                https://polze.net
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="{Binding CurrentStrings.ContactLabel}" />
                        <TextBlock HorizontalAlignment="Center">
                            <Hyperlink NavigateUri="mailto:plexrefresh@polze.net"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                plexrefresh@polze.net
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
